POLYGON_API_KEY=your_polygon_api_key
# Top 20 S&P 500 by market cap (comma-separated, no spaces)
WATCHED_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,BRK.B,TSLA,LLY,AVGO,JPM,V,UNH,XOM,WMT,MA,PG,COST,HD,NFLX

GCP_PROJECT_ID=stockadvisor-498000
GCP_REGION=us-central1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_TO_EMAIL=alerts@example.com

# Agentic AI (WO-11) — Vertex uses GCP ADC; OpenAI is fallback
# OPENAI_API_KEY=sk-...
# VERTEX_AI_MODEL=gemini-1.5-flash
# CONFIDENCE_THRESHOLD=0.70
# ESCALATION_THRESHOLD=0.90
# COOLDOWN_WINDOW_MINUTES=10

# Notification service — Pushover (primary); optional email/Teams/Twilio via POST /channels
# Create app: https://pushover.net/apps/build — copy App Token + your User Key
PUSHOVER_APP_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key
# PUSHOVER_DEVICE=iphone   # optional: limit to one registered device name

# Local pipeline testing (rule engine → agentic-ai → Pushover)
# CONFIDENCE_THRESHOLD=0.01
# ESCALATION_THRESHOLD=0.99
# COOLDOWN_WINDOW_MINUTES=1
# AGENTIC_TEST_MODE=1

# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_CHANNEL_ID=C0123456789
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=alerts@your-verified-domain.com
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15551234567
# TWILIO_TO_NUMBER=+15559876543
# TWILIO_MODE=sms
