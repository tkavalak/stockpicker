# Generated by infra/scripts/provision.sh after terraform apply.
# Copy to streaming.env or source in Cloud Run service deployments (WO-5+).

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
ENVIRONMENT=dev

PUBSUB_TOPIC_RAW_MARKET_EVENTS=raw-market-events
PUBSUB_TOPIC_ENRICHED_MARKET_EVENTS=enriched-market-events
PUBSUB_TOPIC_TRIGGER_EVENTS=trigger-events
PUBSUB_TOPIC_ALERT_DECISIONS=alert-decisions
PUBSUB_TOPIC_RAW_DLQ=raw-market-events-dlq
PUBSUB_TOPIC_ENRICHED_DLQ=enriched-market-events-dlq

PUBSUB_SUBSCRIPTION_MARKET_EVENT_PROCESSOR=market-event-processor-raw-market-events
PUBSUB_SUBSCRIPTION_RULE_ENGINE=rule-engine-enriched-market-events
PUBSUB_SUBSCRIPTION_AGENTIC_AI=agentic-ai-trigger-events
PUBSUB_SUBSCRIPTION_NOTIFICATION=notification-alert-decisions

FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION_RULE_CONFIGS=rule_configs
FIRESTORE_COLLECTION_NOTIFICATION_CONFIGS=notification_configs
FIRESTORE_COLLECTION_AGENT_STATE=agent_state

REDIS_HOST=10.0.0.3
REDIS_PORT=6379
REDIS_CONNECTION_STRING=10.0.0.3:6379

SECRET_STREAMING_PIPELINE_CONFIG=stock-picker-dev-streaming-pipeline-config
